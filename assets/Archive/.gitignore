__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
.env
.pytest_cache/
.idea/
config/exchanges.toml
config/local.toml

# pytest coverage artifacts
.coverage
.coverage.*
htmlcov/

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock

# Agent memory layer (spec 014): high-volume runtime data — preserved
# locally for analysis, not committed. The curated SKILL.md files in
# agent_skills/ are the git-tracked artifacts.
agent_memory/

# Per-skill runtime access state (access_count / last_accessed_at).
# Auto-bumped every time EvolvingSkillProvider picks a skill into a prompt;
# kept in a sidecar next to SKILL.md so git-tracked content stays
# diff-stable. Lives at agent_skills/<name>/.access_state.json and at
# the test-fixture mirror under tests/fixtures/skills/.
**/.access_state.json

# Runtime logs (uvicorn / scheduler / etc) — local development convenience.
logs/

/.claude