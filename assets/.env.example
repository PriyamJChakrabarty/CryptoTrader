# backend/.env
# Get a free key at https://console.groq.com -> API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of exact allowed frontend origins (CORS). Only
# needed when deployed; defaults to http://localhost:3000 for local dev.
FRONTEND_ORIGIN=https://your-app.vercel.app

# Optional: regex for origins that change per deploy, e.g. Vercel preview
# URLs (https://<project>-<random-hash>-<team>.vercel.app). Matches both
# preview and production deployments of your Vercel project in one go.
FRONTEND_ORIGIN_REGEX=https://your-app.*\.vercel\.app

# frontend/.env.local
# URL of the deployed (or local) backend.
NEXT_PUBLIC_BACKEND_URL=https://your-app.up.railway.app
